# ==========================
# Application
# ==========================
NODE_ENV=development
APP_PORT=3000
APP_NAME=erpnext-middleware
APP_URL=http://localhost:3000

# ==========================
# Database (PostgreSQL)
# ==========================
# DB_URL=postgresql://user:password@localhost:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=erpnext_middleware
DB_SYNCHRONIZE=false
DB_LOGGING=true

# ==========================
# Redis
# ==========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================
# JWT
# ==========================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ==========================
# API Keys (Internal)
# ==========================
INTERNAL_API_KEY=your-internal-api-key-change-in-production
WEBHOOK_SECRET=your-webhook-secret-change-in-production

# ==========================
# ERPNext
# ==========================
ERPNEXT_BASE_URL=https://your-erpnext.example.com
ERPNEXT_API_KEY=your-erpnext-api-key
ERPNEXT_API_SECRET=your-erpnext-api-secret
ERPNEXT_COMPANY=Your Company Name
ERPNEXT_DEFAULT_WAREHOUSE=Stores - YC
ERPNEXT_DEFAULT_PRICE_LIST=Standard Selling

# ==========================
# Amazon Seller API
# ==========================
AMAZON_CLIENT_ID=your-amazon-client-id
AMAZON_CLIENT_SECRET=your-amazon-client-secret
AMAZON_REFRESH_TOKEN=your-amazon-refresh-token
AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV
AMAZON_SELLER_ID=your-seller-id
AMAZON_REGION=eu-west-1
AMAZON_ENDPOINT=https://sellingpartnerapi-eu.amazon.com
AMAZON_AWS_ACCESS_KEY=your-aws-access-key
AMAZON_AWS_SECRET_KEY=your-aws-secret-key
AMAZON_AWS_ROLE_ARN=arn:aws:iam::your-account:role/your-role

# ==========================
# Flipkart Seller API
# ==========================
FLIPKART_APP_ID=your-flipkart-app-id
FLIPKART_APP_SECRET=your-flipkart-app-secret
FLIPKART_ACCESS_TOKEN=your-flipkart-access-token
FLIPKART_API_URL=https://api.flipkart.net/sellers
FLIPKART_AFFILIATE_ID=your-affiliate-id

# ==========================
# BullMQ / Queues
# ==========================
QUEUE_ORDERS_CONCURRENCY=5
QUEUE_INVENTORY_CONCURRENCY=3
QUEUE_PRODUCTS_CONCURRENCY=3
QUEUE_PRICING_CONCURRENCY=3
QUEUE_SHIPMENTS_CONCURRENCY=5
QUEUE_RETRY_CONCURRENCY=2
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY=5000

# ==========================
# Scheduler (Cron)
# ==========================
CRON_FETCH_ORDERS=*/15 * * * *
CRON_SYNC_INVENTORY=*/30 * * * *
CRON_SYNC_PRICES=0 * * * *
CRON_RETRY_FAILED=*/10 * * * *
CRON_CLEANUP_LOGS=0 0 * * *

# ==========================
# Rate Limiting
# ==========================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ==========================
# Logging
# ==========================
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m
