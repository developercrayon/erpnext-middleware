_id\":\"A21TJRUUN4KGV\"}],\"care_instructions\":[{\"value\":\"Wipe Clean With A Dry Or Slightly Damp Cloth\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"installation_type\":[{\"value\":\"Wall Mounted\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"number_of_shelves\":[{\"value\":\"3\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"included_components\":[{\"value\":\"Wooden Wall Display Shelf\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_package_weight\":[{\"unit\":\"kilograms\",\"value\":1.5,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"product_description\":[{\"value\":\"Transform any bare wall into a stylish and functional display with this minimalist wooden wall shelf. Crafted from solid natural wood with a warm, honey-toned finish, this vertical wall-mounted shelf features three open tiers that are perfectly spaced to hold your everyday essentials. Measuring 90 cm in height and 10 cm in width and depth, its slim, space-saving design makes it ideal for bedrooms, or living areas where floor space is limited. Each tier provides a sturdy ledge to neatly organise small plants, decorative vases, books, or knick-knacks. The natural wood grain texture adds a touch of warmth and Scandinavian-inspired charm to any interior décor. Whether you use it to display your favourite skincare products or a small floral arrangement, this elegant shelf brings both order and beauty to your space. Easy to mount on the wall, it is a versatile addition to any home.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"shelf_bracket_shape\":[{\"value\":\"Concealed Bracket\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"is_assembly_required\":[{\"value\":true,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"assembly_instructions\":[{\"value\":\"Mount The Shelf On The Wall Using The Provided Hardware. Mark The Desired Position On The Wall, Drill Holes At The Marked Points, Insert Wall Plugs, And Secure The Shelf Using Screws. Ensure The Shelf Is Level Before Tightening Fully.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_depth_width_height\":[{\"depth\":{\"unit\":\"centimeters\",\"value\":10},\"width\":{\"unit\":\"centimeters\",\"value\":10},\"height\":{\"unit\":\"centimeters\",\"value\":90},\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_package_dimensions\":[{\"width\":{\"unit\":\"centimeters\",\"value\":15},\"height\":{\"unit\":\"centimeters\",\"value\":15},\"length\":{\"unit\":\"centimeters\",\"value\":95},\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"product_site_launch_date\":[{\"value\":\"2026-06-25T08:19:33.431Z\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"recommended_browse_nodes\":[{\"value\":\"1380538031\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"specific_uses_for_product\":[{\"value\":\"Home Decor Display, Plant Display, and Home Organization\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"packer_contact_information\":[{\"value\":\"Manufacturer/Seller Contact Information Not Specified\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"recommended_uses_for_product\":[{\"value\":\"Home Organization\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"assembly_instructions_description\":[{\"value\":\"Wall-mounted Installation Required. Attach Mounting Hardware To Wall Studs Or Use Appropriate Wall Anchors. Align Shelf Bracket With Mounted Hardware And Secure In Place. No Additional Assembly Required As Shelf Arrives Pre-assembled.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"is_green_purchasing_law_compliant\":[{\"value\":true,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"supplier_declared_dg_hz_regulation\":[{\"value\":\"not_applicable\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"rtip_manufacturer_contact_information\":[{\"value\":\"319, Sagar Complex, Joshonath Chowk, Bhavnagar, Gujarat - 364001\",\"marketplace_id\":\"A21TJRUUN