ual Compartments\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"variation_theme\":[{\"name\":\"FURNITURE_FINISH/NUMBER_OF_SHELVES\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"weight_capacity\":[{\"maximum\":[{\"unit\":\"kilograms\",\"value\":12}],\"minimum\":[{\"unit\":\"kilograms\",\"value\":1}],\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"furniture_finish\":[{\"value\":\"Walnut Wood Finish\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"number_of_pieces\":[{\"value\":1,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"care_instructions\":[{\"value\":\"Wipe Clean With A Dry Or Slightly Damp Cloth\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"installation_type\":[{\"value\":\"Wall Mounted\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"number_of_shelves\":[{\"value\":\"16\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"included_components\":[{\"value\":\"Wooden Wall Display Shelf\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Comes with Durable Metal Hooks, Mounting Screws, and Plastic Support Legs for Easy Wall Installation or Stable Placement on Tables, Countertops, and Other Flat Surfaces\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_package_weight\":[{\"unit\":\"grams\",\"value\":1800,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"product_description\":[{\"value\":\"Transform any wall into a charming display with the Woodwolf Wooden Wall Display Shelf, featuring a 4x4 grid layout with 16 individual compartments. Crafted from solid wood with a beautiful Walnut wood finish, Backpanel material MDF + Lemination this rustic shelf is perfect for showcasing your favourite mug collection, small plants, trinkets, or decorative items. Measuring 52 cm wide x 52 cm tall x 9 cm deep, it offers ample space in each compartment while maintaining a compact, stylish profile. The shelf arrives pre-assembled, requiring only simple wall mounting using the provided hardware — compatible with wall studs or appropriate wall anchors. With a weight capacity of up to 12 kg, it is sturdy enough to hold a variety of items securely. Ideal for living rooms, kitchens, or home offices, this wall-mounted display shelf adds a warm, rustic charm to any interior. Care is simple — just wipe clean with a dry or slightly damp cloth to maintain its natural beauty.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"shelf_bracket_shape\":[{\"value\":\"Square Grid\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"is_assembly_required\":[{\"value\":true,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"assembly_instructions\":[{\"value\":\"Mount The Shelf On The Wall Using The Provided Hardware. Mark The Desired Position On The Wall, Drill Holes At The Marked Points, Insert Wall Plugs, And Secure The Shelf Using Screws. Ensure The Shelf Is Level Before Tightening Fully.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_depth_width_height\":[{\"depth\":{\"unit\":\"centimeters\",\"value\":10},\"width\":{\"unit\":\"centimeters\",\"value\":49},\"height\":{\"unit\":\"centimeters\",\"value\":49},\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_package_dimensions\":[{\"width\":{\"unit\":\"centimeters\",\"value\":51},\"height\":{\"unit\":\"centimeters\",\"value\":51},\"length\":{\"unit\":\"centimeters\",\"value\":11},\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"product_site_launch_date\":[{\"value\":\"2026-06-17T05:38:42.584Z\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"recommended_browse_nodes\":[{\"value\":\"1380538031\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"specific_uses_for_product\":[{\"value\":\"Mug Display\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Books\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Decorative Items\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"packer_contact