},{\"value\":\"SPACIOUS DIMENSIONS: Measures 63.5 cm wide x 63.5 cm tall x 9 cm deep with a 15 mm shelf thickness, offering ample space to organise and showcase your mug collection.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"STURDY CONSTRUCTION: Crafted from solid wood with a walnut finish, this wall-mounted shelf supports a weight capacity of up to 15 kilograms across all 25 compartments.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"EASY INSTALLATION: Arrives pre-assembled and requires only wall mounting. Simply attach the provided hardware to wall studs or anchors, align the shelf, and secure it in place.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"CARE INSTRUCTIONS: Maintain the shelf's natural beauty by wiping it clean with a dry or slightly damp cloth. Suitable for living rooms and other display spaces.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"manufacturer\":[{\"value\":\"Woodwolf®\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"model_number\":[{\"value\":\"wa-wds-55-wl-bb\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"product_name\":[{\"value\":\"Wooden Wall Display Shelf 25 Sections 5x5 Grid Walnut Wood Finish, Back Panel\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"mounting_type\":[{\"value\":\"Wall Mount\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_type_name\":[{\"value\":\"Wall Display Shelf with MDF + Lemination material Backpanel\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_dimensions\":[{\"width\":{\"unit\":\"centimeters\",\"value\":71},\"height\":{\"unit\":\"centimeters\",\"value\":71},\"length\":{\"unit\":\"centimeters\",\"value\":9},\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"number_of_items\":[{\"value\":1,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"number_of_packs\":[{\"value\":1,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"shelf_thickness\":[{\"uni