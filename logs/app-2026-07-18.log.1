m.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"WALL-MOUNTED DESIGN: Arrives pre-assembled and mounts securely to the wall using provided hardware; simply mark, drill, and fix in place for a clean, space-saving display.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"GENEROUS WEIGHT CAPACITY: Supports up to 7 kg in total, making it suitable for holding mugs, small plants, books, and other lightweight decorative pieces with ease.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"EASY MAINTENANCE: Requires minimal upkeep — simply wipe clean with a dry or slightly damp cloth to keep the shelf looking fresh and well-maintained.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"manufacturer\":[{\"value\":\"Woodwolf®\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"model_number\":[{\"value\":\"wa-wds-33-wl-wb\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"product_name\":[{\"value\":\"Wooden Wall Display Shelf - 9 Compartments (3x3 Grid), Walnut Wood Finish\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"mounting_type\":[{\"value\":\"Wall Mount\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_type_name\":[{\"value\":\"Wall Display Shelf\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_dimensions\":[{\"width\":{\"unit\":\"centimeters\",\"value\":44},\"height\":{\"unit\":\"centimeters\",\"value\":44},\"length\":{\"unit\":\"centimeters\",\"value\":9},\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"number_of_items\":[{\"value\":1,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"number_of_packs\":[{\"value\":1,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"shelf_thickness\":[{\"unit\":\"miles\",\"value\":15,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"special_feature\":[{\"value\":\"9 Individual Compartments\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"variation_theme\":[{\"name\":\"FURNITURE_FINISH/