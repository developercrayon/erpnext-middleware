k Bottom\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Matte Finish\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Ceramic Body\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Splash-resistant Lid\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Heat Resistant Handle\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"care_instructions\":[{\"value\":\"Hand Wash Only\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Not Microwave Safe\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Not Dishwasher Safe\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Wipe Cork Base With Damp Cloth Only\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Do Not Submerge Cork Base In Water\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"drinking_cup_form\":[{\"type\":\"coffee_cup\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_width_height\":[{\"width\":{\"unit\":\"centimeters\",\"value\":12},\"height\":{\"unit\":\"centimeters\",\"value\":11},\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"is_dishwasher_safe\":[{\"value\":true,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"material_type_free\":[{\"value\":\"Ceramic\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Cork\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"included_components\":[{\"value\":\"Ceramic Coffee Mug\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Cork Base\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Lid\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_package_weight\":[{\"unit\":\"grams\",\"value\":450,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"product_description\":[{\"value\":\"Elevate your daily cof