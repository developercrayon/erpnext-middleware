id\":\"A21TJRUUN4KGV\"}],\"weight_capacity\":[{\"maximum\":[{\"unit\":\"kilograms\",\"value\":15}],\"minimum\":[{\"unit\":\"kilograms\",\"value\":5}],\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"furniture_finish\":[{\"value\":\"Natural Clear Matte Finish\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"number_of_pieces\":[{\"value\":1,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"care_instructions\":[{\"value\":\"Wipe Clean With A Dry Or Slightly Damp Cloth\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"installation_type\":[{\"value\":\"Wall Mounted\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"number_of_shelves\":[{\"value\":\"25\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"included_components\":[{\"value\":\"Wall-mounted Shelf Unit\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"},{\"value\":\"Comes with Durable Metal Hooks, Mounting Screws, and Plastic Support Legs for Easy Wall Installation or Stable Placement on Tables, Countertops, and Other Flat Surfaces.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_package_weight\":[{\"unit\":\"grams\",\"value\":7500,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"product_description\":[{\"value\":\"Transform your kitchen or living space with this beautifully crafted wooden mug display shelf made from Pine Wood, designed to showcase your cherished mug collection in style. Featuring a classic grid layout with 25 individual compartments arranged across 5 rows and 5 columns (5x5 Grid Structure), this wall-mounted shelf keeps each mug neatly separated and easily accessible. The warm, natural Clear Matte wood finish adds a contemporary charm to any room, complementing a wide range of interior décor styles from farmhouse to modern minimalist. Each compartment is generously sized to accommodate standard mugs comfortably, making it ideal for collectors and coffee or tea enthusiasts alike. The sturdy wooden construction ensures long-lasting durability, while the open-front design allows you to display your favourite pieces as a decorative focal point on any wall. Whether you are organising a growing collection or simply looking to add character to your kitchen, this mug rack is both a practical storage solution and an eye-catching wall accent. Mugs shown in images are not included.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"shelf_bracket_shape\":[{\"value\":\"Square Grid\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"is_assembly_required\":[{\"value\":true,\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"assembly_instructions\":[{\"value\":\"Mount The Shelf Unit Onto The Wall Using The Provided Hardware. Align The Bracket Holes On The Back Of The Unit With Wall Studs For Secure Installation. Use A Spirit Level To Ensure The Shelf Is Perfectly Horizontal Before Tightening All Screws.\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_depth_width_height\":[{\"depth\":{\"unit\":\"centimeters\",\"value\":9},\"width\":{\"unit\":\"centimeters\",\"value\":76},\"height\":{\"unit\":\"centimeters\",\"value\":76},\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"item_package_dimensions\":[{\"width\":{\"unit\":\"centimeters\",\"value\":78},\"height\":{\"unit\":\"centimeters\",\"value\":78},\"length\":{\"unit\":\"centimeters\",\"value\":12},\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"product_site_launch_date\":[{\"value\":\"2026-06-24T08:02:09.657Z\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"recommended_browse_nodes\":[{\"value\":\"1380538031\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"specific_uses_for_product\":[{\"value\":\"Mug Display\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"packer_contact_information\":[{\"value\":\"319, Sagar Complex, Joshonath Chowk, Bhavnagar, Gujarat - 364001\",\"language_tag\":\"en_IN\",\"marketplace_id\":\"A21TJRUUN4KGV\"}],\"recommended_uses_for_product\":[{\"value\":\"Mug Stor